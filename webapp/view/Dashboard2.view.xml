<mvc:View controllerName="QualityPortal.controller.Dashboard2"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:layout="sap.ui.layout"
	xmlns:core="sap.ui.core"
	xmlns:viz="sap.viz.ui5.controls">

	<Page>
		<customHeader>
			<Bar>
				<contentLeft>
					<Button icon="sap-icon://nav-back" text="Back" press="onNavigateToDashboard1"/>
				</contentLeft>
				<contentMiddle>
					<Title text="Incident Dashboard - EHSM Portal"/>
				</contentMiddle>
				<contentRight>
					<Button icon="sap-icon://log" text="Logout" press="onLogout"/>
					
				</contentRight>
			</Bar>
		</customHeader>

		<content>
			<layout:Grid defaultSpan="L3 M6 S12" class="sapUiMediumMarginTop">
				<Panel headerText="Total Incidents" class="cardPanel">
					<VBox class="sapUiSmallMargin">
						<ObjectNumber id="kpiTotalIncidents" unit="Incidents"/>
					</VBox>
				</Panel>
				<Panel headerText="New Incidents" class="cardPanel">
					<VBox class="sapUiSmallMargin">
						<ObjectNumber id="kpiNew" unit="New" state="Information"/>
					</VBox>
				</Panel>
				<Panel headerText="Closed/Reviewed" class="cardPanel">
					<VBox class="sapUiSmallMargin">
						<ObjectNumber id="kpiReviewed" unit="Closed" state="Success"/>
					</VBox>
				</Panel>
				<Panel headerText="Voided" class="cardPanel">
					<VBox class="sapUiSmallMargin">
						<ObjectNumber id="kpiVoided" unit="Voided" state="Error"/>
					</VBox>
				</Panel>
			</layout:Grid>

			<layout:Grid id="chartGrid" defaultSpan="L6 M6 S12" class="sapUiMediumMarginTop">
				<Panel class="cardPanel"><viz:VizFrame id="chart1" width="100%" height="300px"/></Panel>
				<Panel class="cardPanel"><viz:VizFrame id="chart2" width="100%" height="300px"/></Panel>
				<Panel class="cardPanel"><viz:VizFrame id="chart3" width="100%" height="300px"/></Panel>
				<Panel class="cardPanel"><viz:VizFrame id="chart4" width="100%" height="300px"/></Panel>
			</layout:Grid>

			<Panel id="tablePanel" headerText="Incidents Table" class="cardTable sapUiMediumMarginTop">
				<Table id="lotTable" growing="true" growingScrollToLoad="true" items="{lot>/results}" noDataText="No incident records found">
					<columns>
						<Column><Text text="Incident ID"/></Column>
						<Column><Text text="Title"/></Column>
						<Column><Text text="Created On"/></Column>
						<Column><Text text="Created By"/></Column>
						<Column><Text text="Status"/></Column>
						<Column><Text text="Category"/></Column>
						<Column><Text text="Group"/></Column>
						<Column><Text text="Location"/></Column>
					</columns>
					<items>
						<ColumnListItem>
							<cells>
								<Text text="{lot>IncidentId}"/>
								<Text text="{lot>Title}"/>
								<Text text="{path: 'lot>CreatedOn', type: 'sap.ui.model.type.Date', formatOptions: { pattern: 'yyyy-MM-dd' }}"/>
								<Text text="{lot>CreatedBy}"/>
								<Text text="{lot>IncidentStatus}"/>
								<Text text="{lot>IncidentCategory}"/>
								<Text text="{lot>IncidentGroup}"/>
								<Text text="{lot>Location}"/>
							</cells>
						</ColumnListItem>
					</items>
				</Table>
			</Panel>
		</content>
	</Page>
</mvc:View>
