<mvc:View controllerName="QualityPortal.controller.Dashboard1" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:layout="sap.ui.layout"
	xmlns:core="sap.ui.core" xmlns:viz="sap.viz.ui5.controls">
	<Page>
		<customHeader>
			<Bar>
				<contentLeft>
						<Button icon="sap-icon://log" text="Logout" press="onLogout"/>
				</contentLeft>
				<contentMiddle>
					<Title text="Risk Assessment - EHSM Portal"/>
				</contentMiddle>
				<contentRight>
					<Button icon="sap-icon://navigation-right-arrow" text="Next" press="onNavigateToDashboard2"/>
				</contentRight>
			</Bar>
		</customHeader>
		<content>
			<!-- KPI Cards -->
			<layout:Grid defaultSpan="L4 M6 S12" class="sapUiMediumMarginTop">
				<Panel headerText="Total Assessments" class="cardPanel">
					<VBox class="sapUiSmallMargin"><ObjectNumber number="{risk>/total}" unit="Records"/></VBox>
				</Panel>
				<Panel headerText="Unique Team Members" class="cardPanel">
					<VBox class="sapUiSmallMargin"><ObjectNumber number="{risk>/members}" unit="People" state="Success"/></VBox>
				</Panel>
				<Panel headerText="Unique Roles" class="cardPanel">
					<VBox class="sapUiSmallMargin"><ObjectNumber number="{risk>/roles}" unit="Roles" state="Information"/></VBox>
				</Panel>
			</layout:Grid>
			<!-- Charts -->
			<layout:Grid id="chartGrid" defaultSpan="L6 M6 S12" class="sapUiMediumMarginTop">
				<Panel class="cardPanel"><viz:VizFrame id="barChart" width="100%" height="300px"/></Panel>
				<Panel class="cardPanel"><viz:VizFrame id="lineChart" width="100%" height="300px"/></Panel>
			</layout:Grid>
			<!-- Table -->
			<Panel id="tablePanel" headerText="Risk Assessment Records" class="cardTable sapUiMediumMarginTop">
				<Table items="{risk>/results}" growing="true" growingScrollToLoad="true">
					<columns>
						<Column><Text text="Team Member"/></Column>
						<Column><Text text="Role"/></Column>
						<Column><Text text="Regulation"/></Column>
						<Column><Text text="Risk Key Ref"/></Column>
						<Column><Text text="Created On"/></Column>
					</columns>
					<items>
						<ColumnListItem>
							<cells>
								<Text text="{risk>AsmtTeamMember}"/>
								<Text text="{risk>Role}"/>
								<Text text="{risk>Regulation}"/>
								<Text text="{risk>RiskKeyRef}"/>
								<Text text="{path: 'risk>CreatedOnAt', type: 'sap.ui.model.type.Date', formatOptions: { pattern: 'yyyy-MM-dd' }}"/>
							</cells>
						</ColumnListItem>
					</items>
				</Table>
			</Panel>
		</content>
	</Page>
</mvc:View>